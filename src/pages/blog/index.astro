---
import '../../styles/landing.css';
import { getCollection } from 'astro:content';
import Nav from '../../components/Nav.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog — Luke Oliver Rall</title>
    <meta name="description" content="Thoughts on entrepreneurship, media, and building." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Inter', sans-serif;
        background: #05050a;
        color: #f0f0f0;
        min-height: 100vh;
      }

      .blog-hero {
        padding: 10rem 2rem 4rem;
        text-align: center;
      }

      .blog-hero .label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #e63946;
        margin-bottom: 1rem;
      }

      .blog-hero h1 {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }

      .blog-hero p {
        color: rgba(240,240,240,0.5);
        font-size: 1.1rem;
        max-width: 500px;
        margin: 0 auto;
      }

      .posts-grid {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 2rem 8rem;
        display: grid;
        gap: 1.5rem;
      }

      .post-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 16px;
        padding: 2rem;
        text-decoration: none;
        color: inherit;
        display: block;
        transition: border-color 0.3s ease, background 0.3s ease, transform 0.3s ease;
      }

      .post-card:hover {
        border-color: rgba(230,57,70,0.4);
        background: rgba(230,57,70,0.05);
        transform: translateY(-2px);
      }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
      }

      .post-date {
        font-size: 0.8rem;
        color: rgba(240,240,240,0.4);
      }

      .post-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .tag {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #e63946;
        background: rgba(230,57,70,0.1);
        border: 1px solid rgba(230,57,70,0.2);
        padding: 0.2rem 0.6rem;
        border-radius: 100px;
      }

      .post-title {
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        margin-bottom: 0.5rem;
        line-height: 1.3;
      }

      .post-description {
        color: rgba(240,240,240,0.5);
        font-size: 0.95rem;
        line-height: 1.6;
      }

      .post-arrow {
        margin-top: 1.25rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: #e63946;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        opacity: 0;
        transform: translateX(-4px);
        transition: opacity 0.2s ease, transform 0.2s ease;
      }

      .post-card:hover .post-arrow {
        opacity: 1;
        transform: translateX(0);
      }

      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: rgba(240,240,240,0.3);
      }

      .empty-state h2 {
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
        color: rgba(240,240,240,0.5);
      }
    </style>
  </head>
  <body>
    <Nav />

    <section class="blog-hero">
      <p class="label">Writing</p>
      <h1>The Blog</h1>
      <p>Thoughts on entrepreneurship, media, and building things from scratch.</p>
    </section>

    <div class="posts-grid">
      {posts.length === 0 ? (
        <div class="empty-state">
          <h2>No posts yet</h2>
          <p>Check back soon — first post coming shortly.</p>
        </div>
      ) : (
        posts.map((post) => (
          <a class="post-card" href={`/blog/${post.id}`}>
            <div class="post-meta">
              <span class="post-date">
                {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                  year: 'numeric', month: 'long', day: 'numeric'
                })}
              </span>
              {post.data.tags && (
                <div class="post-tags">
                  {post.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            {post.data.description && (
              <p class="post-description">{post.data.description}</p>
            )}
            <div class="post-arrow">Read more →</div>
          </a>
        ))
      )}
    </div>
  </body>
</html>