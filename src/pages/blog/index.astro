---
import '../../styles/landing.css';
import { getCollection } from 'astro:content';
import Nav from '../../components/Nav.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog — Luke Oliver Rall</title>
    <meta name="description" content="Thoughts on entrepreneurship, media, and building." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Inter', sans-serif;
        background: #05050a;
        color: #f0f0f0;
        min-height: 100vh;
      }

      .blog-hero {
        padding: 10rem 2rem 4rem;
        text-align: center;
      }

      .blog-hero .label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #e63946;
        margin-bottom: 1rem;
      }

      .blog-hero h1 {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }

      .blog-hero p {
        color: rgba(240,240,240,0.5);
        font-size: 1.1rem;
        max-width: 500px;
        margin: 0 auto;
      }

      .posts-grid {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 2rem 8rem;
        display: grid;
        gap: 1.5rem;
      }

      .post-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 16px;
        padding: 2rem;
        text-decoration: none;
        color: inherit;
        display: block;
        transition: border-color 0.3s ease, background 0.3s ease, transform 0.3s ease;
      }

      .post-card:hover {
        border-color: rgba(230,57,70,0.4);
        background: rgba(230,57,70,0.05);
        transform: translateY(-2px);
      }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
      }

      .post-date {
        font-size: 0.8rem;
        color: rgba(240,240,240,0.4);
      }

      .post-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .tag {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #e63946;
        background: rgba(230,57,70,0.1);
        border: 1px solid rgba(230,57,70,0.2);
        padding: 0.2rem 0.6rem;
        border-radius: 100px;
      }

      .post-title {
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        margin-bottom: 0.5rem;
        line-height: 1.3;
      }

      .post-description {
        color: rgba(240,240,240,0.5);
        font-size: 0.95rem;
        line-height: 1.6;
      }

      .post-arrow {
        margin-top: 1.25rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: #e63946;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        opacity: 0;
        transform: translateX(-4px);
        transition: opacity 0.2s ease, transform 0.2s ease;
      }

      .post-card:hover .post-arrow {
        opacity: 1;
        transform: translateX(0);
      }

      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: rgba(240,240,240,0.3);
      }

      .empty-state h2 {
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
        color: rgba(240,240,240,0.5);
      }

      /* Blog Footer */
      .blog-footer {
        background: #0a0a12;
        border-top: 1px solid rgba(255,255,255,0.06);
        padding: 2.5rem 2rem;
      }
      .blog-footer-inner {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .blog-footer-logo {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        text-decoration: none;
        color: #fff;
        font-family: 'Inter', sans-serif;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.05em;
      }
      .blog-footer-tag {
        font-size: 0.7rem;
        color: rgba(240,240,240,0.35);
        font-weight: 400;
        letter-spacing: 0.02em;
      }
      .blog-footer-socials {
        display: flex;
        gap: 1rem;
        align-items: center;
      }
      .blog-footer-socials a {
        color: rgba(240,240,240,0.4);
        transition: color 0.3s;
        display: flex;
        align-items: center;
      }
      .blog-footer-socials a:hover { color: #e63946; }
      .blog-footer-copy {
        font-size: 0.78rem;
        color: rgba(240,240,240,0.3);
      }
      .blog-footer-copy a {
        color: #e63946;
        text-decoration: none;
      }
      @media (max-width: 600px) {
        .blog-footer-inner { flex-direction: column; text-align: center; }
      }
    </style>
  </head>
  <body>
    <Nav />

    <section class="blog-hero">
      <p class="label">Writing</p>
      <h1>The Blog</h1>
      <p>Thoughts on entrepreneurship, media, and building things from scratch.</p>
    </section>

    <div class="posts-grid">
      {posts.length === 0 ? (
        <div class="empty-state">
          <h2>No posts yet</h2>
          <p>Check back soon — first post coming shortly.</p>
        </div>
      ) : (
        posts.map((post) => (
          <a class="post-card" href={`/blog/${post.id}`}>
            <div class="post-meta">
              <span class="post-date">
                {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                  year: 'numeric', month: 'long', day: 'numeric'
                })}
              </span>
              {post.data.tags && (
                <div class="post-tags">
                  {post.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            {post.data.description && (
              <p class="post-description">{post.data.description}</p>
            )}
            <div class="post-arrow">Read more →</div>
          </a>
        ))
      )}
    </div>

    <footer class="blog-footer">
      <div class="blog-footer-inner">
        <a href="/" class="blog-footer-logo">
          <span>LUKE RALL</span>
          <span class="blog-footer-tag">Born to Build *.*</span>
        </a>
        <div class="blog-footer-socials">
          <a href="https://x.com/LukeOliverRall" target="_blank" rel="noopener noreferrer" aria-label="X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.instagram.com/lukerall" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/luke-oliver-rall-138568171/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452z"/></svg>
          </a>
        </div>
        <p class="blog-footer-copy">© 2026 Luke Oliver Rall · <a href="/">lukeoliverrall.com</a></p>
      </div>
    </footer>
  </body>
</html>