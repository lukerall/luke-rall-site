---
import Nav from '../components/Nav.astro';
import '../styles/landing.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Media Gallery — Luke Oliver Rall</title>
    <meta name="description" content="Photos, videos, and moments from interviews, events, and behind the scenes with Luke Oliver Rall.">
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Media Gallery — Luke Oliver Rall" />
    <meta property="og:description" content="Photos, videos, and moments from interviews, events, and behind the scenes." />
    <meta property="og:url" content="https://lukeoliverrall.com/gallery" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@LukeOliverRall" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" href="/favicon.ico">
  </head>
  <body>
    <div class="glow" id="glow"></div>
    <Nav />

    <section class="gallery-hero">
      <div class="container">
        <div class="eyebrow reveal">Media Gallery</div>
        <h1 class="section-h2 reveal d1">Gallery<em style="color:var(--red)">.</em></h1>
        <p class="section-lead reveal d2">Photos, videos, and moments — from interviews to events to behind the scenes.</p>
        <a href="/" class="gallery-back-link reveal d3">← Back to main site</a>
      </div>
    </section>

    <section class="gallery-grid-section">
      <div class="container">
        <div class="gallery-placeholder-grid">

          <div class="gallery-slot reveal d1">
            <div class="gallery-slot-inner">
              <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Coming Soon</span>
            </div>
          </div>

          <div class="gallery-slot reveal d2">
            <div class="gallery-slot-inner">
              <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Coming Soon</span>
            </div>
          </div>

          <div class="gallery-slot reveal d3">
            <div class="gallery-slot-inner">
              <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Coming Soon</span>
            </div>
          </div>

          <div class="gallery-slot reveal d2">
            <div class="gallery-slot-inner">
              <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
              <span>Coming Soon</span>
            </div>
          </div>

          <div class="gallery-slot reveal d3">
            <div class="gallery-slot-inner">
              <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Coming Soon</span>
            </div>
          </div>

          <div class="gallery-slot reveal d4">
            <div class="gallery-slot-inner">
              <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
              <span>Coming Soon</span>
            </div>
          </div>

          <div class="gallery-slot reveal d3">
            <div class="gallery-slot-inner">
              <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Coming Soon</span>
            </div>
          </div>

          <div class="gallery-slot reveal d4">
            <div class="gallery-slot-inner">
              <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              <span>Coming Soon</span>
            </div>
          </div>

          <div class="gallery-slot reveal d4">
            <div class="gallery-slot-inner">
              <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
              <span>Coming Soon</span>
            </div>
          </div>

        </div>

        <p class="gallery-coming-soon-note reveal d3">Content being added — check back soon.</p>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-bottom" style="padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.06); margin-top: 0;">
          <p class="footer-copy">© 2026 Luke Oliver Rall · All rights reserved</p>
          <div class="footer-bottom-links">
            <a href="/">Home</a>
            <a href="/#media">Media</a>
            <a href="/#connect">Contact</a>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      window.addEventListener('load', () => {
        const io = new IntersectionObserver(entries => {
          entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
        }, { threshold: 0.10, rootMargin: '0px 0px -20px 0px' });
        document.querySelectorAll('.reveal').forEach(el => io.observe(el));
      });

      if (window.matchMedia('(hover: hover)').matches) {
        const glow = document.getElementById('glow');
        let mx = 0, my = 0, gx = 0, gy = 0;
        document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; glow.classList.add('on'); });
        document.addEventListener('mouseleave', () => glow.classList.remove('on'));
        (function loop() { gx += (mx - gx) * 0.07; gy += (my - gy) * 0.07; glow.style.left = gx + 'px'; glow.style.top = gy + 'px'; requestAnimationFrame(loop); })();
      }
    </script>
  </body>
</html>
