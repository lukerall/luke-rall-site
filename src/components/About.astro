<section class="about" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-img-wrap reveal">
        <img
          class="about-img"
          src="/headshot.jpg"
          alt="Luke Oliver Rall"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        >
        <div class="about-img-placeholder" style="display:none">
          <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
          <span>Add headshot.jpg</span>
        </div>
      </div>
      <div class="about-text">
        <div class="eyebrow reveal">About Me</div>
        <h2 class="section-h2 reveal d1">Born to Build<em style="color:var(--red)">.</em></h2>
        <p class="reveal d2">I'm Luke Oliver Rall — born and raised in Durban, South Africa, and obsessed with building things that actually matter. At 21, I've founded and co-founded companies spanning digital marketing, content production, and creative strategy.</p>
        <p class="reveal d3">My work sits at the intersection of media, technology, and business — turning ideas into companies that scale. Whether it's creating content that moves audiences or campaigns that drive real commercial results, I bring an ownership mindset to everything.</p>
        <div class="about-tags reveal d3">
          <span class="tag">Media &amp; Content</span>
          <span class="tag">Digital Marketing</span>
          <span class="tag">Entrepreneurship</span>
          <span class="tag">South Africa 🇿🇦</span>
          <span class="tag">USA 2026 🇺🇸</span>
        </div>
        <div class="about-stats reveal d4">
          <div class="stat">
            <span class="stat-num counter" data-to="2">0</span>
            <div class="stat-lbl">Companies</div>
          </div>
          <div class="stat">
            <span class="stat-num counter" data-to="21">0</span>
            <div class="stat-lbl">Years Old</div>
          </div>
          <div class="stat">
            <span class="stat-num" style="font-size:1.3rem">🚀</span>
            <div class="stat-lbl">Always Moving</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  window.addEventListener('load', () => {
    const co = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target;
        const target = +el.dataset.to;
        let n = 0;
        const step = Math.ceil(target / 28);
        const t = setInterval(() => {
          n = Math.min(n + step, target);
          el.textContent = n;
          if (n >= target) clearInterval(t);
        }, 45);
        co.unobserve(el);
      });
    }, { threshold: 0.5 });

    document.querySelectorAll('.counter').forEach(el => co.observe(el));
  });
</script>
