<section class="newsletter" id="newsletter">
  <div class="container">
    <div class="eyebrow reveal">Stay in the Loop</div>
    <h2 class="section-h2 reveal d1">Join the Newsletter<em style="color:var(--red)">.</em></h2>
    <p class="section-lead reveal d2">Insights on entrepreneurship, digital marketing, and the journey of building companies — straight to your inbox.</p>
    <form
      class="nl-form reveal d3"
      onsubmit="event.preventDefault();this.innerHTML='<p style=\'color:var(--red);font-weight:600;padding:0.8rem 0\'>You\'re in! 🚀 Talk soon.</p>'"
    >
      <input type="email" placeholder="Your email address" required>
      <button type="submit" class="btn btn-red-light">Subscribe</button>
    </form>
  </div>
</section>
