<section class="hero" id="top">
  <div class="stars" id="stars"></div>
  <div class="particles" id="particles"></div>

  <div class="hero-inner">
    <!-- Text side -->
    <div class="hero-content">
      <div class="hero-eyebrow">Entrepreneur · Founder · Builder</div>
      <h1 class="hero-name">Luke Oliver<br><em>Rall</em></h1>
      <p class="hero-tagline">Born to Build <em>*.*</em></p>
      <p class="hero-sub">21-year-old South African entrepreneur building companies at the intersection of media, tech &amp; business. Durban born. Moving to the USA in 2026.</p>

      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-num">2</span>
          <span class="hero-stat-lbl">Companies</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">21</span>
          <span class="hero-stat-lbl">Years Old</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num hero-stat-flags">🇿🇦→🇺🇸</span>
          <span class="hero-stat-lbl">2026</span>
        </div>
      </div>

      <div class="hero-cta">
        <a href="#ventures" class="btn btn-red">
          Explore My Ventures
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 7h12M7 1l6 6-6 6"/></svg>
        </a>
        <a href="#media" class="btn btn-ghost">
          Watch Latest Interview
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21" fill="currentColor"/></svg>
        </a>
      </div>
    </div>

    <!-- Profile photo side -->
    <div class="hero-photo-wrap">
      <div class="hero-photo-ring">
        <!-- Replace /images/luke-profile.jpg with your actual profile photo -->
        <img
          src="/headshot.jpg"
          alt="Luke Oliver Rall"
          class="hero-photo"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="hero-photo-fallback">
          <svg width="60" height="60" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="4"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
          <span>Add headshot.jpg<br>to /public/</span>
        </div>
      </div>
      <div class="hero-photo-glow"></div>
    </div>
  </div>

  <div class="scroll-cue">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<script is:inline>
  (function () {
    const c = document.getElementById('stars');
    if (!c) return;
    for (let i = 0; i < 120; i++) {
      const s = document.createElement('div');
      s.className = 'star';
      const size = Math.random() * 2.5 + 0.5;
      const maxOp = (Math.random() * 0.6 + 0.4).toFixed(2);
      const dur = (Math.random() * 5 + 4).toFixed(1);
      s.style.cssText = `width:${size}px;height:${size}px;left:${Math.random() * 100}%;top:${Math.random() * 100}%;--d:${dur}s;--max-op:${maxOp};animation-delay:${(Math.random() * 8).toFixed(1)}s;`;
      c.appendChild(s);
    }
  })();

  (function () {
    const c = document.getElementById('particles');
    if (!c) return;
    for (let i = 0; i < 22; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      const sz = 2 + Math.random() * 4;
      p.style.cssText = `width:${sz}px;height:${sz}px;left:${Math.random() * 100}%;animation-duration:${7 + Math.random() * 9}s;animation-delay:${Math.random() * 12}s;`;
      c.appendChild(p);
    }
  })();

  window.addEventListener('scroll', () => {
    if (scrollY > innerHeight) return;
    const name = document.querySelector('.hero-name');
    if (name) name.style.transform = `translateY(${scrollY * 0.05}px)`;
  }, { passive: true });
</script>
