  <script is:inline>
    (function() {
      var outer = document.getElementById('interviewOuter');
      var track = document.getElementById('interviewTrack');
      var cards = document.querySelectorAll('.interview-card');
      var dots  = document.querySelectorAll('.carousel-dot');
      var prev  = document.getElementById('iPrev');
      var next  = document.getElementById('iNext');
      var total = cards.length;
      var current = 0;

      function loadIframe(i) {
        var el = cards[i].querySelector('iframe[data-src]');
        if (el) { el.src = el.dataset.src; el.removeAttribute('data-src'); }
      }

      function pauseIframe(i) {
        var el = cards[i].querySelector('iframe[src]');
        if (!el) return;
        if (el.src.includes('youtube.com')) {
          try { el.contentWindow.postMessage(JSON.stringify({event:'command',func:'pauseVideo'}), '*'); } catch(e){}
        } else {
          el.src = el.src; // Rumble: reload to stop audio
        }
      }

      function center() {
        var outerW = outer.offsetWidth;
        var card = cards[current];
        var cardLeft = card.offsetLeft;
        var cardW = card.offsetWidth;
        track.style.transform = 'translateX(' + (outerW / 2 - cardLeft - cardW / 2) + 'px)';
      }

      function goTo(i) {
        pauseIframe(current);
        current = ((i % total) + total) % total;
        cards.forEach(function(c, idx) { c.classList.toggle('active', idx === current); });
        dots.forEach(function(d, idx) { d.classList.toggle('active', idx === current); });
        center();
        loadIframe(current);
      }

      loadIframe(0);
      center();
      window.addEventListener('resize', center);

      prev.addEventListener('click', function() { goTo(current - 1); });
      next.addEventListener('click', function() { goTo(current + 1); });
      dots.forEach(function(d) {
        d.addEventListener('click', function() { goTo(parseInt(d.dataset.slide)); });
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowLeft') goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
      });
    })();
  </script>

